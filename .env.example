# =====================================================
# BAZ Marketing Agency — environment template
# Copy to `.env.local` and fill in real values.
# =====================================================

# Public site URL (used for canonical, OG, sitemap)
NEXT_PUBLIC_SITE_URL=https://baz.agency

# Booking URL (Cal.com, Calendly, etc.)
NEXT_PUBLIC_BOOKING_URL=https://cal.com/baz/growth-call

# Brand stats shown in hero. Replace with real numbers before launch.
NEXT_PUBLIC_BRANDS_SCALED=240+
NEXT_PUBLIC_COUNTRIES_SERVED=14
NEXT_PUBLIC_TEAM_SIZE=12
NEXT_PUBLIC_SENIOR_ONLY=100%

# =========================================
# Backend wiring (optional but recommended)
# =========================================

# Connect to the BAZ meta-ecosystem API for live agent demo,
# lead forwarding, and live monitors.
# Leave empty for standalone mode (simulated AI, console-logged leads).
BAZ_API_URL=http://localhost:4000
BAZ_API_TOKEN=

# Generic lead webhook fallback (Slack, HubSpot, Zapier, etc.)
LEAD_INTAKE_URL=
LEAD_INTAKE_TOKEN=

# Google Analytics 4 — leave empty to disable
NEXT_PUBLIC_GA4_ID=
