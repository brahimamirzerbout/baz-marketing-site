# =====================================================
# BAZ Marketing Agency — local development environment
# Copy to `.env.local` and adjust for your machine.
# =====================================================

# Local dev server origin (used for canonical, OG, sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Booking URL (Cal.com, Calendly, etc.).
# Leave empty to fall back to a prefilled mailto.
NEXT_PUBLIC_BOOKING_URL=

# Brand stats shown in the hero trust strip. The page hides any stat
# whose value is empty/null. Replace with verified numbers before launch.
NEXT_PUBLIC_BRANDS_SCALED=
NEXT_PUBLIC_COUNTRIES_SERVED=
NEXT_PUBLIC_TEAM_SIZE=
NEXT_PUBLIC_SENIOR_ONLY=100%

# =========================================
# Backend wiring (optional but recommended)
# =========================================

# Connect to the BAZ meta-ecosystem API for live agent demo,
# lead forwarding, and live monitors.
# Leave empty for standalone mode (simulated AI, console-logged leads).
BAZ_API_URL=
BAZ_API_TOKEN=

# Generic lead webhook fallback (Slack, HubSpot, Zapier, etc.)
LEAD_INTAKE_URL=
LEAD_INTAKE_TOKEN=

# Admin token — required to enable /admin/leads and GET /api/leads.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_TOKEN=replace-me

# Email (Resend). Leave RESEND_API_KEY empty to disable.
RESEND_API_KEY=
NOTIFY_EMAIL=
NOTIFY_FROM=BAZ Site <noreply@baz.agency>

# =========================================
# Analytics
# =========================================
# Google Analytics 4 property ID. Leave empty to disable.
# The dataLayer still pushes events even without GA4 — useful for dev
# and for wiring up other tools (Mixpanel, PostHog, etc.).
NEXT_PUBLIC_GA4_ID=

# =========================================
# Lead scoring
# =========================================
# Set to "off" to disable the background LeadGen scoring agent.
# Default is "on" — the agent scores each new lead via the LLM.
LEAD_SCORING=on

# =========================================
# Owner bootstrap (first boot only)
# =========================================
# The first time the DB is created, an "owner" user is seeded with
# these credentials. After first login, change the password in
# /admin/settings or the operator console.
OWNER_EMAIL=owner@baz.agency
OWNER_PASSWORD=changeme-on-first-login

# =========================================
# Hero stats (homepage trust strip)
# =========================================
# Leave blank to hide the cell. Defaults in dev: 240+, 12, 14, 100%.
NEXT_PUBLIC_BRANDS_SCALED=
NEXT_PUBLIC_COUNTRIES_SERVED=
NEXT_PUBLIC_TEAM_SIZE=
NEXT_PUBLIC_SENIOR_ONLY=

# =========================================
# Partner stack shown on hero (comma-separated)
# =========================================
NEXT_PUBLIC_STACK=Ollama,GitHub,Vercel,Linear,Stripe,Resend

# =========================================
# BAZ Marketing Hub — public URL
# Used by the live status card on the homepage and the /marketing-hub CTA.
# In dev: http://localhost:3010. In prod: https://marketing.baz.com
# =========================================
NEXT_PUBLIC_HUB_URL=http://localhost:3010

# =========================================
# Supabase (@supabase/server)
# =========================================
# Copy from your Supabase dashboard → Connect → Server.
# The secret key is in API Keys settings — never commit it.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# Supabase Auth (for SSR client — must be public/anonymously accessible)
NEXT_PUBLIC_SUPABASE_URL=https://uyqgmdrzyapbbvmaumvk.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_RhlyuI-vQGilK1oBhGZd_w_xs11x4ps

# PostgreSQL direct connection string (for the sync DB adapter).
# Get from Supabase dashboard → Settings → Database → Connection string
# Format: postgresql://postgres.{ref}:{password}@aws-0-{region}.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=
